{
  "name": "sky2ctestautomation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:safari": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=Mobile Chrome",
    "test:parallel": "playwright test --workers=3",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean",
    "allure:open": "allure open",
    "allure:serve": "allure serve",
    "install:browsers": "playwright install",
    "codegen": "playwright codegen",
    "trace:viewer": "playwright show-trace"
  },
  "keywords": ["playwright", "automation", "testing"],
  "author": "",
  "license": "ISC",
  "description": "Playwright Test Automation Framework",
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^24.0.1",
    "allure-playwright": "^2.13.2",
    "allure-commandline": "^2.27.0"
  }
}
